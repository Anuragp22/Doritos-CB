JWT_SECRET=replace-with-a-long-random-string

POSTGRES_USER=doritos
POSTGRES_PASSWORD=doritos
POSTGRES_DB=doritos

CLIENT_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000

# Local MODEL/server.py on the host:
QWEN_API_URL=http://host.docker.internal:5000/generate
EMBED_API_URL=http://host.docker.internal:5000/embed
RERANK_API_URL=http://host.docker.internal:5000/rerank
# Modal serverless GPU (after `modal deploy MODEL/modal_app.py`):
# QWEN_API_URL=https://<workspace>--doritos-ai-model-fastapi-app.modal.run/generate
# EMBED_API_URL=https://<workspace>--doritos-ai-model-fastapi-app.modal.run/embed
# RERANK_API_URL=https://<workspace>--doritos-ai-model-fastapi-app.modal.run/rerank
MODEL_ID=Qwen/Qwen2-VL-2B-Instruct-AWQ
EMBED_MODEL_ID=BAAI/bge-small-en-v1.5
RERANK_MODEL_ID=BAAI/bge-reranker-base

NODE_ENV=production
